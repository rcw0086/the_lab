# Environment
ENVIRONMENT=development
DEBUG=false

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=the_lab

# JWT Authentication
# REQUIRED: JWT_SECRET_KEY must be set (minimum 32 characters recommended)
# Generate a secure key with: openssl rand -hex 32
# Example: JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console  # "console" for development, "json" for production
